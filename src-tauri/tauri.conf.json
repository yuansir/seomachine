{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SEO Machine",
  "version": "0.1.0",
  "identifier": "com.seomachine.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SEO Machine",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: http://ipc.localhost https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "public.app-category.productivity",
    "copyright": "Copyright 2026 SEO Machine",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../python-scripts/*": "python-scripts/"
    }
  },
  "plugins": {
    "sql": {}
  }
}
